<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TimeSheetPro Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/water.css@2/out/dark.css">
    <style>
        .task-card { border: 1px solid #444; padding: 15px; margin-bottom: 10px; border-radius: 8px; }
        .summary-text { width: 100%; height: 80px; font-style: italic; color: #fff; background: #222; border: 1px solid #555; border-radius: 4px; padding: 8px; margin: 10px 0; }
        .hours { font-weight: bold; color: #007acc; }
        select { margin-right: 10px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #444; padding: 10px; text-align: left; }
        th { background-color: #333; }
    </style>
</head>
<body>
    <h1>🕒 TimeSheetPro</h1>
    <p>Review your hourly AI summaries and assign them to Klient tasks.</p>
    
    <div id="report-container">
        <h2>Pending Drafts (Action Required)</h2>
        <div id="drafts-list">Loading pending drafts...</div>
    </div>

    <div id="export-container" style="margin-top: 40px;">
        <h2>Weekly Export (Approved)</h2>
        <p>Copy-paste these finalized entries into Klient at the end of the week.</p>
        <div id="export-list">Loading weekly export...</div>
    </div>

    <div id="settings-container" style="margin-top: 40px; padding: 20px; border: 1px solid #444; border-radius: 8px; background-color: #111;">
        <h2>⚙️ Task Management</h2>
        <p>Import your Klient tasks manually so you can assign your time to them.</p>
        
        <div style="margin-bottom: 10px;">
            <label style="display:block; font-weight:bold; margin-bottom:5px;">Paste Klient Data (Copy directly from Klient list view)</label>
            <p style="font-size: 0.8em; color: #aaa; margin-top: 0;">Expected columns: Owner, Status, <strong>Project</strong>, <strong>Task Name</strong>, <strong>Account</strong></p>
            <textarea id="csv-data" style="width: 100%; height: 100px; font-family: monospace; background: #222; color: #fff; border: 1px solid #555; padding: 8px; border-radius: 4px;" placeholder="Matt Bryant	In Progress	4424103 - OakTree Mobility	Project Acceptance	OakTree Mobility"></textarea>
        </div>
        <button onclick="importCSV()">Import Tasks</button>
        <span id="import-status" style="margin-left: 10px; color: limegreen;"></span>
    </div>

    <script>
        let allTasks = [];

        async function importCSV() {
            const csv = document.getElementById('csv-data').value;
            if (!csv.trim()) return alert('Please enter some CSV data');
            
            const status = document.getElementById('import-status');
            status.innerText = 'Importing...';
            
            const res = await fetch('/api/tasks/import/csv', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ csv })
            });
            
            if (res.ok) {
                const data = await res.json();
                status.innerText = `✅ Successfully imported ${data.imported} tasks!`;
                document.getElementById('csv-data').value = '';
                loadDrafts(); // Reload dropdowns
            } else {
                status.innerText = '❌ Import failed.';
                status.style.color = 'red';
            }
            
            setTimeout(() => { status.innerText = ''; status.style.color = 'limegreen'; }, 5000);
        }

        async function loadTasks() {
            const res = await fetch('/api/tasks');
            allTasks = await res.json();
        }

        async function loadDrafts() {
            await loadTasks();
            const res = await fetch('/api/drafts');
            const data = await res.json();
            
            const container = document.getElementById('drafts-list');
            container.innerHTML = '';

            if (data.length === 0) {
                container.innerHTML = '<p>No pending drafts! You are all caught up.</p>';
                return;
            }

            data.forEach(item => {
                const div = document.createElement('div');
                div.className = 'task-card';

                // Build task dropdown
                let optionsHtml = '<option value="">-- Select Klient Task --</option>';
                allTasks.forEach(t => {
                    optionsHtml += `<option value="${t.id}">${t.name}</option>`;
                });

                let rawHtml = '';
                if (item.raw_data) {
                    try {
                        const rawArray = JSON.parse(item.raw_data);
                        rawHtml = '<details style="margin-bottom:10px; font-size:0.8em; color:#aaa;"><summary style="cursor:pointer;">View Raw Data</summary><ul style="padding-left:20px;">';
                        rawArray.forEach(a => rawHtml += `<li>${a.replace(/</g, '&lt;')}</li>`);
                        rawHtml += '</ul></details>';
                    } catch(e) {}
                }

                div.innerHTML = `
                    <p style="font-size:0.8em; color:#888;">Generated: ${new Date(item.created_at).toLocaleString()}</p>
                    <p class="hours">Total Time: ${item.hours} hours</p>
                    <textarea id="notes-${item.id}" class="summary-text">${item.notes}</textarea>
                    ${rawHtml}
                    <select id="task-select-${item.id}">${optionsHtml}</select>
                    <button onclick="approveDraft('${item.id}')">Approve & Assign</button>
                `;
                container.appendChild(div);
            });
        }

        async function loadWeeklyExport() {
            const res = await fetch('/api/export/weekly');
            const data = await res.json();
            
            const container = document.getElementById('export-list');
            container.innerHTML = '';

            if (data.length === 0) {
                container.innerHTML = '<p>No approved entries yet.</p>';
                return;
            }

            let tableHtml = `
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Project</th>
                            <th>Task</th>
                            <th>Hours</th>
                            <th>Comments</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            data.forEach(item => {
                // Ensure daily comments are formatted nicely (e.g. if combined)
                const comments = item.combined_notes.startsWith('- ') ? item.combined_notes : `- ${item.combined_notes}`;
                tableHtml += `
                    <tr>
                        <td>${new Date(item.date).toLocaleDateString()}</td>
                        <td>${item.project_name}</td>
                        <td>${item.task_name}</td>
                        <td class="hours">${item.total_hours.toFixed(2)}</td>
                        <td style="white-space: pre-wrap;">${comments}</td>
                    </tr>
                `;
            });

            tableHtml += `
                    </tbody>
                </table>
            `;
            container.innerHTML = tableHtml;
        }

        async function approveDraft(id) {
            const taskId = document.getElementById(`task-select-${id}`).value;
            const notes = document.getElementById(`notes-${id}`).value;

            if (!taskId) {
                alert('Please select a Klient Task first!');
                return;
            }

            const res = await fetch(`/api/drafts/${id}/approve`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ task_id: taskId, notes: notes })
            });

            if (res.ok) {
                loadDrafts(); // Refresh list
                loadWeeklyExport(); // Refresh export table
            } else {
                alert('Failed to approve draft.');
            }
        }

        loadDrafts();
        loadWeeklyExport();
    </script>
</body>
</html>
