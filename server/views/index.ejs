<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TimeSheetPro | Architect Dashboard</title>
    <style>
        * { box-sizing: border-box; }
        body { display: flex; height: 100vh; margin: 0; font-family: sans-serif; background: #111; color: #eee; }
        #sidebar { width: 250px; background: #222; padding: 20px; border-right: 1px solid #444; flex-shrink: 0; }
        #main-content { flex: 1; padding: 40px; overflow-y: auto; width: calc(100% - 250px); }
        .view { display: none; width: 100%; }
        .view.active { display: block; }
        .task-card { border: 1px solid #444; padding: 20px; margin-bottom: 20px; border-radius: 8px; background: #1a1a1a; width: 100%; }
        .summary-text { width: 100%; height: 80px; color: #fff; background: #000; border: 1px solid #555; border-radius: 4px; padding: 10px; margin: 10px 0; }
        .hours { font-weight: bold; color: #007acc; font-size: 1.2em; }
        nav button { display: block; width: 100%; margin-bottom: 10px; text-align: left; padding: 12px; cursor: pointer; background: #333; border: 1px solid #555; color: #fff; }
        nav button:hover { background: #444; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #444; padding: 12px; text-align: left; }
        th { background-color: #333; }
        textarea { width: 100%; min-height: 100px; font-family: monospace; background: #222; color: #fff; border: 1px solid #555; padding: 8px; border-radius: 4px; }
    </style>
</head>
<body>
    <nav id="sidebar">
        <h2>TimeSheetPro</h2>
        <button onclick="showView('drafts')">📋 Pending Drafts</button>
        <button onclick="showView('export')">📊 Weekly Export</button>
        <button onclick="showView('recent')">🕒 Recent Activity</button>
        <button onclick="showView('tasks')">⚙️ Manage Tasks</button>
        <button onclick="showView('prompt')">🧠 AI Personality</button>
    </nav>

    <main id="main-content">
        <div id="drafts" class="view active">
            <h1>Pending Drafts</h1>
            <div id="drafts-list">Loading...</div>
        </div>

        <div id="export" class="view">
            <h1>Weekly Export</h1>
            <div id="export-list">Loading...</div>
        </div>

        <div id="recent" class="view">
            <h1>Recent Raw Activity</h1>
            <div id="recent-list">Loading...</div>
        </div>

        <div id="tasks" class="view">
            <h1>Task Management</h1>
            <div style="margin-bottom: 30px;">
                <label>Paste Klient Data (Owner, Status, Project, Task, Account):</label>
                <textarea id="csv-data" placeholder="Matt Bryant	In Progress	ProjectName	TaskName	AccountName"></textarea>
                <button onclick="importCSV()">Import Tasks</button>
                <span id="import-status"></span>
            </div>
            
            <h3>Active Tasks Database</h3>
            <div id="active-tasks-list">Loading...</div>
        </div>

        <div id="prompt" class="view">
            <h1>AI Personality</h1>
            <textarea id="prompt-data" style="width:100%; height: 500px;"></textarea>
            <button onclick="savePrompt()">Save Prompt</button>
            <span id="prompt-status"></span>
        </div>
    </main>

    <script>
        let allTasks = [];
        function showView(id) {
            document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        async function loadTasks() {
            const res = await fetch('/api/tasks');
            allTasks = await res.json();
            const projectRes = await fetch('/api/projects');
            const projects = await projectRes.json();
            
            const container = document.getElementById('active-tasks-list');
            container.innerHTML = `
                <table>
                    <thead><tr><th>Account</th><th>Project</th><th>Task</th><th>Owner</th><th>Status</th></tr></thead>
                    <tbody>
                        ${allTasks.map(t => {
                            const prj = projects.find(p => p.id === t.project_id);
                            return `<tr><td>${t.account_name}</td><td>${prj ? prj.name : t.project_id}</td><td>${t.name}</td><td>${t.owner}</td><td>${t.status}</td></tr>`;
                        }).join('')}
                    </tbody>
                </table>`;
        }

        async function loadRecent() {
            const res = await fetch('/api/activities/recent');
            const data = await res.json();
            const container = document.getElementById('recent-list');
            container.innerHTML = `
                <table style="width:100%; border-collapse: collapse;">
                    <thead>
                        <tr>
                            <th style="width: 10%">Time</th>
                            <th style="width: 15%">Process</th>
                            <th style="width: 25%">Window</th>
                            <th style="width: 35%">OCR Text</th>
                            <th style="width: 15%">Screenshot</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${data.map(a => `
                            <tr>
                                <td>${new Date(a.timestamp).toLocaleTimeString()}</td>
                                <td>${a.process_name}</td>
                                <td>${a.window_title}</td>
                                <td style="font-size: 0.8em; color: #aaa;">${a.ocr_text ? a.ocr_text.substring(0, 100) + '...' : 'N/A'}</td>
                                <td>
                                    ${a.image_data ? `
                                        <button onclick="toggleImage('${a.id}')">View</button>
                                        <div id="img-${a.id}" style="display:none; position:fixed; top:10%; left:20%; z-index:1000; background:#000; padding:10px; border:2px solid #555;">
                                            <img src="data:image/jpeg;base64,${a.image_data}" style="max-width:800px;" />
                                            <button onclick="document.getElementById('img-${a.id}').style.display='none'">Close</button>
                                        </div>
                                    ` : 'N/A'}
                                </td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>`;
        }

        function toggleImage(id) {
            const el = document.getElementById('img-' + id);
            el.style.display = el.style.display === 'none' ? 'block' : 'none';
        }

        async function loadDrafts() {
            await loadTasks();
            const res = await fetch('/api/drafts');
            const data = await res.json();
            const container = document.getElementById('drafts-list');
            container.innerHTML = data.map(item => `
                <div class="task-card">
                    <p>Generated: ${new Date(item.created_at).toLocaleString()}</p>
                    <p class="hours">Total: ${item.hours} hours</p>
                    <textarea id="notes-${item.id}" class="summary-text">${item.notes}</textarea>
                    <select id="task-select-${item.id}">${allTasks.map(t => `<option value="${t.id}">${t.name}</option>`).join('')}</select>
                    <button onclick="approveDraft('${item.id}')">Approve</button>
                </div>
            `).join('');
        }

        async function loadWeeklyExport() {
            const res = await fetch('/api/export/weekly');
            const data = await res.json();
            document.getElementById('export-list').innerHTML = `<table><tr><th>Date</th><th>Project</th><th>Task</th><th>Hours</th><th>Notes</th></tr>` + 
                data.map(i => `<tr><td>${new Date(i.date).toLocaleDateString()}</td><td>${i.project_name}</td><td>${i.task_name}</td><td>${i.total_hours.toFixed(2)}</td><td>${i.combined_notes}</td></tr>`).join('') + `</table>`;
        }

        async function importCSV() {
            const csv = document.getElementById('csv-data').value;
            const res = await fetch('/api/tasks/import/csv', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ csv }) });
            if (res.ok) { alert('Imported!'); loadTasks(); }
        }

        async function loadPrompt() {
            const res = await fetch('/api/settings/prompt');
            const data = await res.json();
            document.getElementById('prompt-data').value = data.prompt;
        }

        async function savePrompt() {
            const prompt = document.getElementById('prompt-data').value;
            await fetch('/api/settings/prompt', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt }) });
            alert('Saved!');
        }

        async function approveDraft(id) {
            const taskId = document.getElementById('task-select-' + id).value;
            const notes = document.getElementById('notes-' + id).value;
            await fetch('/api/drafts/' + id + '/approve', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ task_id: taskId, notes: notes }) });
            loadDrafts(); loadWeeklyExport();
        }

        loadDrafts(); loadWeeklyExport(); loadPrompt(); loadRecent();
    </script>
</body>
</html>
