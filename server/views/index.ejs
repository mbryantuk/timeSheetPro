<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TimeSheetPro | Architect Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/water.css@2/out/dark.css">
    <style>
        body { margin: 0; font-family: sans-serif; background: #111; color: #eee; }
        #sidebar { width: 100%; background: #222; padding: 20px; border-bottom: 1px solid #444; display: flex; gap: 10px; }
        #main-content { padding: 40px; overflow-y: auto; width: 100%; }
        .view { display: none; width: 100%; }
        .view.active { display: block; }
        .task-card { border: 1px solid #444; padding: 20px; margin-bottom: 20px; border-radius: 8px; background: #1a1a1a; width: 100%; }
        .summary-text { width: 100%; height: 80px; color: #fff; background: #000; border: 1px solid #555; border-radius: 4px; padding: 10px; margin: 10px 0; }
        .hours { font-weight: bold; color: #007acc; font-size: 1.2em; }
        nav button { padding: 12px; cursor: pointer; background: #333; border: 1px solid #555; color: #fff; }
        nav button:hover { background: #444; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #444; padding: 12px; text-align: left; }
        th { background-color: #333; }
        textarea { width: 100%; min-height: 100px; font-family: monospace; background: #222; color: #fff; border: 1px solid #555; padding: 8px; border-radius: 4px; }
    </style>
</head>
<body>
    <nav id="sidebar">
        <h2>TimeSheetPro</h2>
        <div id="ai-status" style="padding: 10px; border: 1px solid #444; border-radius: 4px; background: #333; margin-bottom: 20px;">
            <p id="ai-status-text" style="font-size: 0.8em; margin: 0;">AI Status: Checking...</p>
            <p id="net-status" style="font-size: 0.7em; color: #888; margin-top:5px;">🌐 Sensor: Idle</p>
        </div>
        <button onclick="showView('drafts')">📋 Pending Drafts</button>
        <button onclick="showView('export')">📊 Weekly Export</button>
        <button onclick="showView('recent')">🕒 Recent Activity</button>
        <button onclick="showView('cronlogs')">📜 Cron Logs</button>
        <button onclick="showView('tasks')">⚙️ Manage Tasks</button>
        <button onclick="showView('prompt')">🧠 AI Personality</button>
    </nav>

    <main id="main-content">
        <div id="drafts" class="view active">
            <h1>Pending Drafts</h1>
            <button onclick="abortAI()" style="background:#cc0000; color: white;">Cancel Active AI Summary</button>
            <div id="drafts-list">Loading...</div>
        </div>

        <div id="export" class="view">
            <h1>Weekly Export</h1>
            <div id="export-list">Loading...</div>
        </div>

        <div id="recent" class="view">
            <h1>Recent Raw Activity</h1>
            <div id="recent-list">Loading...</div>
        </div>

        <div id="cronlogs" class="view">
            <h1>Cron Job Logs</h1>
            <div id="cron-logs-list">Loading...</div>
        </div>

        <div id="ollama-ps" class="view">
            <h1>Ollama Status (Memory/Models)</h1>
            <div id="ollama-ps-list">Loading...</div>
        </div>

        <div id="tasks" class="view">
            <h1>Task Management</h1>
            <div style="margin-bottom: 30px;">
                <label>Paste Klient Data (Owner, Status, Project, Task, Account):</label>
                <textarea id="csv-data" placeholder="Matt Bryant	In Progress	ProjectName	TaskName	AccountName"></textarea>
                <button onclick="importCSV()">Import Tasks</button>
                <span id="import-status"></span>
            </div>
            
            <h3>Manual Summarization</h3>
            <p>Force an AI summary for a custom time range (hours).</p>
            <input type="number" id="summary-hours" value="1" min="1" max="24" style="width: 60px;"> hours ago.
            <button onclick="triggerTimeRangeSummary()">Generate AI Summary</button>
            <div id="manual-summary-status" style="margin-top: 10px; font-weight: bold;"></div>

            <h3>Active Tasks Database</h3>
            <div id="active-tasks-list">Loading...</div>
        </div>

        <div id="prompt" class="view">
            <h1>AI Personality</h1>
            <textarea id="prompt-data" style="width:100%; height: 500px;"></textarea>
            <button onclick="savePrompt()">Save Prompt</button>
            <span id="prompt-status"></span>
        </div>
    </main>

    <script>
        let allTasks = [];
        function showView(id) {
            document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        async function loadTasks() {
            const res = await fetch('/api/tasks');
            allTasks = await res.json();
            const projectRes = await fetch('/api/projects');
            const projects = await projectRes.json();
            
            const container = document.getElementById('active-tasks-list');
            container.innerHTML = `
                <table>
                    <thead><tr><th>Account</th><th>Project</th><th>Task</th><th>Owner</th><th>Status</th></tr></thead>
                    <tbody>
                        ${allTasks.map(t => {
                            const prj = projects.find(p => p.id === t.project_id);
                            return `<tr><td>${t.account_name}</td><td>${prj ? prj.name : t.project_id}</td><td>${t.name}</td><td>${t.owner}</td><td>${t.status}</td></tr>`;
                        }).join('')}
                    </tbody>
                </table>`;
        }

        async function loadDrafts() {
            await loadTasks();
            const res = await fetch('/api/drafts');
            const data = await res.json();
            const container = document.getElementById('drafts-list');
            container.innerHTML = data.map(item => `
                <div class="task-card">
                    <p>Generated: ${new Date(item.created_at).toLocaleString()}</p>
                    <p class="hours">Total: ${item.hours} hours</p>
                    <textarea id="notes-${item.id}" class="summary-text">${item.notes}</textarea>
                    <select id="task-select-${item.id}">${allTasks.map(t => `<option value="${t.id}">${t.name}</option>`).join('')}</select>
                    <button onclick="approveDraft('${item.id}')">Approve</button>
                </div>
            `).join('');
        }

        async function loadWeeklyExport() {
            const res = await fetch('/api/export/weekly');
            const data = await res.json();
            const container = document.getElementById('export-list');
            
            let tableHtml = `
                <table id="klient-table" style="width:100%; border-collapse: collapse; font-family: sans-serif;">
                    <thead>
                        <tr style="background: #333;">
                            <th>Account</th>
                            <th>Project</th>
                            <th>Task</th>
                            <th>Hours</th>
                            <th>Comment</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            data.forEach(item => {
                tableHtml += `
                    <tr>
                        <td class="account-cell">...</td>
                        <td>${item.project_name}</td>
                        <td>${item.task_name}</td>
                        <td class="hours">${item.total_hours.toFixed(2)}</td>
                        <td style="white-space: pre-wrap;">${item.combined_notes}</td>
                    </tr>
                `;
            });

            tableHtml += `</tbody></table>
            <button onclick="copyToClipboard()" style="margin-top: 20px; background: #007acc;">Copy for Klient</button>`;
            container.innerHTML = tableHtml;
        }

        function copyToClipboard() {
            const table = document.getElementById("klient-table");
            let range = document.createRange();
            range.selectNode(table);
            window.getSelection().removeAllRanges();
            window.getSelection().addRange(range);
            document.execCommand("copy");
            window.getSelection().removeAllRanges();
            alert("Copied to clipboard! Ready to paste into Klient.");
        }

        async function loadRecent() {
            const res = await fetch('/api/activities/recent');
            const data = await res.json();
            const container = document.getElementById('recent-list');
            container.innerHTML = `
                <table style="width:100%; border-collapse: collapse;">
                    <thead>
                        <tr>
                            <th style="width: 10%">Time</th>
                            <th style="width: 15%">Process</th>
                            <th style="width: 25%">Window</th>
                            <th style="width: 35%">OCR Text</th>
                            <th style="width: 15%">Screenshot</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${data.map(a => `
                            <tr>
                                <td>${new Date(a.timestamp).toLocaleTimeString()}</td>
                                <td>${a.process_name}</td>
                                <td>${a.window_title}</td>
                                <td>
                                    <details>
                                        <summary style="font-size: 0.8em; color: #aaa; cursor: pointer;">
                                            ${a.ocr_text ? a.ocr_text.substring(0, 50) + '...' : 'N/A'}
                                        </summary>
                                        <div style="font-size: 0.8em; color: #fff; background: #333; padding: 10px; margin-top: 5px; border-radius: 4px;">
                                            ${a.ocr_text ? a.ocr_text.replace(/\n/g, '<br>') : 'No text'}
                                        </div>
                                    </details>
                                </td>
                                <td>
                                    ${a.image_data ? `
                                        <button onclick="toggleImage('${a.id}')">View</button>
                                        <div id="img-${a.id}" style="display:none; position:fixed; top:10%; left:20%; z-index:1000; background:#000; padding:10px; border:2px solid #555;">
                                            <img src="data:image/jpeg;base64,${a.image_data}" style="max-width:800px;" />
                                            <button onclick="document.getElementById('img-${a.id}').style.display='none'">Close</button>
                                        </div>
                                    ` : 'N/A'}
                                </td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>`;
        }

        async function loadCronLogs() {
            const res = await fetch('/api/cron-logs');
            const data = await res.json();
            const container = document.getElementById('cron-logs-list');
            container.innerHTML = `
                <table style="width:100%; border-collapse: collapse;">
                    <thead><tr><th>Time</th><th>Message</th></tr></thead>
                    <tbody>
                        ${data.map(l => `<tr><td>${new Date(l.timestamp).toLocaleString()}</td><td>${l.message}</td></tr>`).join('')}
                    </tbody>
                </table>`;
        }

        async function loadOllamaPS() {
            const res = await fetch('/api/ollama-ps');
            const data = await res.json();
            const container = document.getElementById('ollama-ps-list');
            if (data.models && data.models.length > 0) {
                container.innerHTML = `
                    <table style="width:100%; border-collapse: collapse;">
                        <thead><tr><th>Model</th><th>Size (VRAM)</th><th>Expires</th></tr></thead>
                        <tbody>
                            ${data.models.map(m => `<tr><td>${m.name}</td><td>${(m.size_vram / 1024 / 1024 / 1024).toFixed(2)} GB</td><td>${new Date(m.expires_at).toLocaleTimeString()}</td></tr>`).join('')}
                        </tbody>
                    </table>`;
            } else {
                container.innerHTML = '<p>No models currently loaded in memory.</p>';
            }
        }

        function toggleImage(id) {
            const el = document.getElementById('img-' + id);
            el.style.display = el.style.display === 'none' ? 'block' : 'none';
        }

        let lastActivityTime = 0;

        async function updateNetworkStatus() {
            const res = await fetch('/api/activities/recent');
            const data = await res.json();
            const latest = data[0];
            const now = new Date().getTime();

            const netStatus = document.getElementById('net-status');
            if (latest && (now - new Date(latest.timestamp).getTime() < 10000)) {
                netStatus.innerText = '🌐 Sensor: Active';
                netStatus.style.color = 'limegreen';
            } else {
                netStatus.innerText = '🌐 Sensor: Inactive';
                netStatus.style.color = '#888';
            }
        }

        async function updateAIStatus() {
            const res = await fetch('/api/ai-status');
            const data = await res.json();
            document.getElementById('ai-status-text').innerText = data.isSummarizing ? `🤖 ${data.currentTask}` : '🤖 AI: Idle';
        }

        setInterval(() => {
            updateAIStatus();
            updateNetworkStatus();
        }, 2000);

        async function importCSV() {
            const csv = document.getElementById('csv-data').value;
            const res = await fetch('/api/tasks/import/csv', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ csv }) });
            if (res.ok) { alert('Imported!'); loadTasks(); }
        }

        async function triggerTimeRangeSummary() {
            const hours = document.getElementById('summary-hours').value;
            if (!hours) return alert('Select hours');

            const status = document.getElementById('manual-summary-status');
            status.innerText = '🤖 AI is analyzing... (this may take a minute)';
            status.style.color = '#007acc';

            try {
                const res = await fetch('/api/force-cron', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ hours })
                });
                if (res.ok) {
                    status.innerText = '✅ Summary generated!';
                    status.style.color = 'limegreen';
                    loadDrafts();
                } else {
                    status.innerText = '❌ Failed.';
                    status.style.color = 'red';
                }
            } catch (e) {
                status.innerText = '❌ Error.';
                status.style.color = 'red';
            }
        }

        async function loadPrompt() {
            const res = await fetch('/api/settings/prompt');
            const data = await res.json();
            document.getElementById('prompt-data').value = data.prompt;
        }

        async function savePrompt() {
            const prompt = document.getElementById('prompt-data').value;
            await fetch('/api/settings/prompt', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt }) });
            alert('Saved!');
        }

        async function approveDraft(id) {
            const taskId = document.getElementById('task-select-' + id).value;
            const notes = document.getElementById('notes-' + id).value;
            await fetch('/api/drafts/' + id + '/approve', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ task_id: taskId, notes: notes }) });
            loadDrafts(); loadWeeklyExport();
        }

        async function abortAI() {
            await fetch('/api/abort-summary', { method: 'POST' });
            alert('AI summarization aborted.');
        }

        loadDrafts(); loadWeeklyExport(); loadPrompt(); loadRecent(); loadCronLogs(); loadOllamaPS();
        setInterval(updateAIStatus, 2000);
    </script>
</body>
</html>
