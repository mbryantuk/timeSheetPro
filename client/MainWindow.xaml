<Window x:Class="TimeSheetPro.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeSheetPro" Height="40" Width="200"
        WindowStyle="None" AllowsTransparency="True" Background="#EE1E1E1E"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border BorderBrush="#FF3E3E3E" BorderThickness="1" CornerRadius="20">
        <Grid Margin="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center"/>
            
            <TextBlock x:Name="TxtStatus" Grid.Column="1" Text="Monitoring..." Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="10,0" TextTrimming="CharacterEllipsis"/>
            
            <Button Grid.Column="2" Content="×" Foreground="#FF666666" Background="Transparent" BorderThickness="0" FontSize="14" VerticalAlignment="Center" Cursor="Hand" Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
