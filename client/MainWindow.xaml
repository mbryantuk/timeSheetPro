<Window x:Class="TimeSheetPro.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeSheetPro" Height="150" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="#EE1E1E1E"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border BorderBrush="#FF3E3E3E" BorderThickness="1" CornerRadius="8">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header and Status -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TxtStatus" Text="Tracking: [Idle]" Foreground="White" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TxtDetails" Text="Initializing..." Foreground="#FFAAAAAA" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
                <Ellipse x:Name="StatusDot" Grid.Column="1" Width="12" Height="12" Fill="LimeGreen" VerticalAlignment="Top"/>
            </Grid>

            <!-- Task Selector -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,10">
                <TextBlock Text="ACTIVE KLIENT TASK" Foreground="#FF007ACC" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>
                <ComboBox x:Name="ComboTasks" Background="#FF2D2D30" Foreground="White" BorderThickness="0" Height="25">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Footer / Time Display -->
            <Grid Grid.Row="2">
                <TextBlock x:Name="TxtTodayTime" Text="Today: 0.00h" Foreground="White" VerticalAlignment="Center"/>
                <Button Content="REFRESH" HorizontalAlignment="Right" Padding="8,2" Background="#FF3E3E3E" Foreground="White" BorderThickness="0" Click="BtnRefresh_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
